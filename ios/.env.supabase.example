# Copy to .env.supabase and fill with your Supabase project values.

# Database connection string (from Supabase Dashboard > Project Settings > Database)
# Example: postgresql://postgres.[project-ref]:[password]@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres
SUPABASE_DB_URL=postgresql://postgres:[password]@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres

# App-side values used by backup/account flows
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=sb_publishable_replace_me
PAYBOARD_SERVER_URL=https://your-server.example.com
