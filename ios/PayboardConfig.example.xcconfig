SLASH = /
SUPABASE_URL = https:$(SLASH)$(SLASH)your-project.supabase.co
SUPABASE_ANON_KEY = sb_publishable_replace_me
PAYBOARD_SERVER_URL = https:$(SLASH)$(SLASH)your-server.example.com
PAYBOARD_AUTH_URL_SCHEME = payboard
KAKAO_NATIVE_APP_KEY = your_kakao_native_app_key
KAKAO_IOS_URL_SCHEME = kakao$(KAKAO_NATIVE_APP_KEY)
