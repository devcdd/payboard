# Copy to .env.supabase and fill with your Supabase project values.

# Database connection string (from Supabase Dashboard > Project Settings > Database)
# Example: postgresql://postgres.[project-ref]:[password]@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres
SUPABASE_DB_URL=https://your-project-ref.supabase.co

# Optional app-side values for future backup API wiring
SUPABASE_URL=postgresql://postgres:[password]@aws-0-ap-northeast-2.pooler.supabase.com:6543/postgres
SUPABASE_ANON_KEY=your-anon-key
